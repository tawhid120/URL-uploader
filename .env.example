# Telegram Bot Configuration
API_ID=your_api_id_here
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here

# Optional: Pyrogram user session string (for 4GB uploads by Premium users)
SESSION_STR=

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
DB_NAME=url_uploader_bot

# Optional: Log channel ID (for logging downloads)
LOG_CHANNEL=0

# Optional: Force-subscribe channel (username without @, or channel ID)
FSUB_CHANNEL=

# Admin user IDs (comma-separated, e.g. 123456789,987654321)
ADMIN_IDS=

# Optional: Admin Web Dashboard
DASHBOARD_PORT=8080
DASHBOARD_TOKEN=

# Web application port (auto-set by Render, Railway, Heroku, etc.)
# Falls back to DASHBOARD_PORT if not set.
# PORT=8080
